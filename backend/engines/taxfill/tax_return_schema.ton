@schema form_id=BIR51 year_of_assessment=2024/25
  description: "Profits Tax Return - Corporations (BIR51)"
  form_version: 2025
  total_fields: 127

@part part_number=1
  part_name_en: "STATEMENT OF ASSESSABLE PROFITS OR ADJUSTED LOSS"
  part_name_zh: "应评税利润或经调整亏损陈述书"
  field_count: 3

  @field field_id=1.1 box=1
    name_en: "Assessable Profits (before loss brought forward)"
    name_zh: "应评税利润（结转亏损前）"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["Assessable profit"]
    mutually_exclusive_with: [1.2]
    validation_rules: ["must_equal_taxcomp_assessable_profit"]

  @field field_id=1.2 box=2
    name_en: "Adjusted Loss (before loss brought forward)"
    name_zh: "经调整亏损（结转亏损前）"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["Adjusted loss"]
    mutually_exclusive_with: [1.1]

  @field field_id=1.3 box=3
    name_en: "Loss brought forward from prior year"
    name_zh: "上年度结转亏损"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["Loss brought forward", "Unrelieved loss"]

@part part_number=2
  part_name_en: "TAX LIABILITY OR REPAYMENT"
  part_name_zh: "应缴税款或退税"
  field_count: 3

  @field field_id=2.1
    name_en: "Tax Payable"
    name_zh: "应缴税款"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: manual

  @field field_id=2.2
    name_en: "Tax Repayable"
    name_zh: "应退税款"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: manual

  @field field_id=2.3 box=4
    name_en: "Two-tiered profits tax election"
    name_zh: "两级制利得税选择"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: derived
    @decision_tree
      description: "Assessable profit > 0? No -> No. Yes -> Loss b/f > profit? Yes -> No. No -> MANUAL."
      step: "IF Part_1_1 == 0 THEN No"
      step: "IF Part_1_3 > Part_1_1 THEN No"
      step: "ELSE -> MANUAL REVIEW"
      default_if_uncertain: ""
    reasoning: "Two-tiered tax requires manual judgment when loss b/f partially offsets profit"

@part part_number=3
  part_name_en: "SPECIFIED TRANSACTIONS AND MATTERS"
  part_name_zh: "特定交易及事项"
  field_count: 11

  @field field_id=3.1 box=5
    name_en: "Intellectual property payments to non-resident"
    name_zh: "向非居民支付知识产权费用"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: derived
    source_keywords: ["royalty", "intellectual property", "licence fees"]
    derivation_rule: "Yes IF Part_12_14 > 0 ELSE No"
    trigger_field: 12.14

  @field field_id=3.2 box=6
    name_en: "Deemed assessable profits (s.20AE/20AF/20AX/20AY)"
    name_zh: "应评税利润（第20AE/20AF/20AX/20AY条）"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: tax_computation
    derivation_rule: "Yes IF Tax Computation mentions '20AE', '20AF', '20AX', '20AY' ELSE No"
    default_value: "No"

  @field field_id=3.3 box=7
    name_en: "Short/medium term debt instruments (issued before 1 April 2018)"
    name_zh: "短期/中期债务票据（2018年4月1日前发行）"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: tax_computation
    derivation_rule: "Yes IF Tax Computation mentions debt instruments issued before 2018-04-01 ELSE No"
    default_value: "No"

  @field field_id=3.4 box=8
    name_en: "Double taxation relief (s.49/49(1A))"
    name_zh: "双重课税宽减（第49/49(1A)条）"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: tax_computation
    derivation_rule: "Yes IF Tax Computation has 'foreign tax credit', 'double taxation relief', 'Section 49' ELSE No"
    default_value: "No"

  @field field_id=3.5 box=9
    name_en: "Advance ruling obtained"
    name_zh: "已取得事先裁定"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS or Director's Report mentions advance ruling application ELSE No"
    default_value: "No"

  @field field_id=3.6 box=10
    name_en: "Bond issuer/originator (s.40AB/Schedule 17A)"
    name_zh: "债券发行人/始创人（第40AB条/附表17A）"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF company is bond issuer or originator ELSE No"
    default_value: "No"

  @field field_id=3.7 box=11
    name_en: "Deduction for regulatory capital security distribution"
    name_zh: "规管资本证券分派扣除"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: tax_computation
    derivation_rule: "Yes IF Tax Computation mentions regulatory capital security deduction ELSE No"
    default_value: "No"

  @field field_id=3.8 box=12
    name_en: "Permanent establishment in Hong Kong of non-resident"
    name_zh: "非香港居民的香港常设机构"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS or Director's Report indicates PE status ELSE No"
    default_value: "No"

  @field field_id=3.8.1 box=13
    name_en: "Transactions with other parts of non-Hong Kong resident person"
    name_zh: "与非香港居民人士其他部分的交易"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: derived
    derivation_rule: "Yes IF 3.8=Yes AND has transactions ELSE No"
    default_value: "No"

  @field field_id=3.9 box=14
    name_en: "Specified person under s.51AAB/Schedule 65 (electronic filing mandate)"
    name_zh: "第51AAB条/附表65指明人士（电子报税强制规定）"
    value_type: boolean
    fill_rule: 'Tick "No" for 2024/25 or before'
    required: true
    source_preference: fixed
    fixed_value: "No"
    reasoning: "Applicable for year of assessment 2025/26 and subsequent years only"

  @field field_id=3.9.1 box=15
    name_en: "Qualify for paper form filing (s.51AAC(3))"
    name_zh: "符合纸本表格报税资格（第51AAC(3)条）"
    value_type: boolean
    fill_rule: 'Tick "No" for 2024/25 or before'
    required: true
    source_preference: fixed
    fixed_value: "No"
    reasoning: "Applicable for year of assessment 2025/26 and subsequent years only"

@part part_number=4
  part_name_en: "DETAILS OF THE CORPORATION"
  part_name_zh: "公司详情"
  field_count: 4

  @field field_id=4.1
    name_en: "Postal address if different from that printed on this return"
    name_zh: "如与本报税表上印载的地址不同，请填上通讯地址"
    value_type: text
    fill_rule: "Leave blank if same as printed"
    required: false
    source_preference: financial_statements
    source_keywords: ["registered address", "principal place of business"]

  @field field_id=4.2
    name_en: "Telephone Number"
    name_zh: "电话号码"
    value_type: text
    fill_rule: "Enter telephone number"
    required: false
    source_preference: manual

  @field field_id=4.3a
    name_en: "Principal business activity"
    name_zh: "主要业务活动"
    value_type: text
    fill_rule: "Enter principal business activity description"
    required: true
    source_preference: financial_statements
    source_keywords: ["principal activity", "business activity"]

  @field field_id=4.3b box=16
    name_en: "Hong Kong Standard Industrial Classification Code"
    name_zh: "香港标准行业分类编码"
    value_type: text
    fill_rule: "Enter 6-digit HSIC code"
    required: true
    source_preference: manual

@part part_number=5
  part_name_en: "RETURN FORM LANGUAGE"
  part_name_zh: "报税表语文"
  field_count: 1

  @field field_id=5.1
    name_en: "Receive future Profits Tax Returns in CHINESE"
    name_zh: "日后以中文收取利得税报税表"
    value_type: boolean
    fill_rule: "Tick the box if wish to receive in Chinese"
    required: false
    source_preference: fixed
    default_value: "No"

@part part_number=6
  part_name_en: "AUTHORIZED REPRESENTATIVE"
  part_name_zh: "获授权代表"
  field_count: 2
  note: "Part 6 is entirely manual — LLM should NOT attempt to fill any values"

  @field field_id=6.1
    name_en: "Authorized representative name and address"
    name_zh: "获授权代表姓名及地址"
    value_type: text
    fill_rule: "Complete only if representative appointed"
    required: false
    source_preference: manual

  @field field_id=6.2
    name_en: "Representative's Business Registration No."
    name_zh: "获授权代表商业登记号码"
    value_type: text
    fill_rule: "Enter if applicable"
    required: false
    source_preference: manual

@part part_number=7
  part_name_en: "GENERAL MATTERS"
  part_name_zh: "一般事项"
  field_count: 25

  @field field_id=7.1 box=17
    name_en: "Are your accounts required to be audited by law?"
    name_zh: "你的账目是否须依法审计？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: fixed
    fixed_value: "Yes"
    reasoning: "Hong Kong incorporated limited companies are required by law to have audited accounts"

  @field field_id=7.1.1 box=18
    name_en: "Are your accounts audited by a Hong Kong practice unit?"
    name_zh: "你的账目是否由香港执业单位审计？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF auditor signature block shows HK CPA firm ELSE No"

  @field field_id=7.1.2 box=19
    name_en: "Practising certificate number of the certified public accountant"
    name_zh: "执业会计师的执业证书号码"
    value_type: text
    fill_rule: "Enter certificate number"
    required: true
    source_preference: financial_statements
    source_keywords: ["Practising Certificate No.", "CPA"]
    derivation_rule: "Extract from auditor signature block"

  @field field_id=7.2a
    name_en: "Basis period from date"
    name_zh: "评税基期起始日"
    value_type: date
    fill_rule: "Enter From date"
    required: true
    source_preference: financial_statements
    source_keywords: ["For the year ended", "Basis period", "31 March"]

  @field field_id=7.2b
    name_en: "Basis period to date"
    name_zh: "评税基期结束日"
    value_type: date
    fill_rule: "Enter To date"
    required: true
    source_preference: financial_statements
    source_keywords: ["For the year ended", "Basis period", "31 March"]

  @field field_id=7.2c box=20
    name_en: "Is accounting date different from last year?"
    name_zh: "本年度会计日期是否与上年度不同？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: fixed
    fixed_value: "No"
    reasoning: "Same accounting period as prior year unless stated otherwise"

  @field field_id=7.3a box=21
    name_en: "Did you commence business within the basis period?"
    name_zh: "你是否在评税基期内开始经营业务？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF first year of business indicated ELSE No"
    default_value: "No"

  @field field_id=7.3b
    name_en: "Date of commencement"
    name_zh: "开业日期"
    value_type: date
    fill_rule: "Enter date if 7.3a=Yes"
    required: false
    source_preference: manual
    conditional_on: 7.3a

  @field field_id=7.4 box=22
    name_en: "Did you cease business within the basis period?"
    name_zh: "你是否在评税基期内结束经营业务？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF winding up/cessation mentioned ELSE No"
    default_value: "No"

  @field field_id=7.4.1
    name_en: "Date of cessation"
    name_zh: "结束业务日期"
    value_type: date
    fill_rule: "Enter date if 7.4=Yes"
    required: false
    source_preference: manual
    conditional_on: 7.4

  @field field_id=7.4.2a box=23
    name_en: "On cessation, was business transferred to another person?"
    name_zh: "结束业务时，业务是否转让予另一人？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: false
    source_preference: financial_statements
    derivation_rule: "Yes IF cessation AND transfer mentioned ELSE No"
    default_value: "No"
    conditional_on: 7.4

  @field field_id=7.4.2b
    name_en: "Name of person business transferred to"
    name_zh: "业务转让对象名称"
    value_type: text
    fill_rule: "Enter name if 7.4.2a=Yes"
    required: false
    source_preference: manual
    conditional_on: 7.4.2a

  @field field_id=7.4.3 box=24
    name_en: "On cessation, were assets sold/transferred to an associated person?"
    name_zh: "结束业务时，资产是否售予/转让予关联人士？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: false
    source_preference: financial_statements
    derivation_rule: "Yes IF cessation AND associated person transfer mentioned ELSE No"
    default_value: "No"
    conditional_on: 7.4

  @field field_id=7.5 box=25
    name_en: "Elect to align tax treatment of financial instruments with accounting treatment (s.18I-18L)?"
    name_zh: "选择将财务工具的税务处理与会计处理一致（第18I至18L条）？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: fixed
    fixed_value: "No"
    reasoning: "Unless explicitly elected"

  @field field_id=7.6a box=26
    name_en: "Are financial statements prepared in a foreign currency?"
    name_zh: "财务报表是否以外国货币编制？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS prepared in non-HKD currency ELSE No"
    default_value: "No"

  @field field_id=7.6b
    name_en: "Foreign currency used"
    name_zh: "使用的外币币种"
    value_type: text
    fill_rule: "Enter currency if 7.6a=Yes"
    required: false
    source_preference: manual
    conditional_on: 7.6a

  @field field_id=7.6c
    name_en: "Conversion rate to HK$"
    name_zh: "港元换算率"
    value_type: amount
    fill_rule: "Enter conversion rate if 7.6a=Yes"
    required: false
    source_preference: manual
    conditional_on: 7.6a

  @field field_id=7.7 box=27
    name_en: "Are you a private company?"
    name_zh: "你是否为私人公司？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: fixed
    fixed_value: "Yes"
    reasoning: "Most companies filing BIR51 are private companies"

  @field field_id=7.7.1 box=28
    name_en: "Has there been any change in your shareholders during the basis period?"
    name_zh: "在评税基期内，股东是否有任何变动？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF Director's Report or notes mention share transfers/allotments ELSE No"
    default_value: "No"

  @field field_id=7.8 box=29
    name_en: "Were you a party to an amalgamation under s.680 or 681 of the Companies Ordinance?"
    name_zh: "你是否根据《公司条例》第680或681条参与合并？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF section 680/681 mentioned ELSE No"
    default_value: "No"

  @field field_id=7.9 box=30
    name_en: "Were you involved in any processing arrangement in the Chinese Mainland?"
    name_zh: "你是否参与中国内地的任何加工安排？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS mentions contract processing/import processing in Mainland ELSE No"
    default_value: "No"

  @field field_id=7.10 box=31
    name_en: "Are you an insurance corporation commencing RBC regime?"
    name_zh: "你是否为开始实施风险为本资本制度的保险公司？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF insurance company AND RBC regime mentioned ELSE No"
    default_value: "No"

  @field field_id=7.10.1 box=32
    name_en: "RBC one-off adjustment - Income"
    name_zh: "风险为本资本制度一次性调整 - 收入"
    value_type: amount
    fill_rule: 'If NIL, enter "0"'
    required: false
    source_preference: manual
    default_value: "0"
    conditional_on: 7.10

  @field field_id=7.10.1b box=33
    name_en: "RBC one-off adjustment - Loss"
    name_zh: "风险为本资本制度一次性调整 - 亏损"
    value_type: amount
    fill_rule: 'If NIL, enter "0"'
    required: false
    source_preference: manual
    default_value: "0"
    conditional_on: 7.10

  @field field_id=7.10.2 box=34
    name_en: "Elect to spread RBC one-off adjustment over 5 years?"
    name_zh: "选择将一次性调整分5年摊分？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: false
    source_preference: manual
    default_value: "No"
    conditional_on: 7.10

  @field field_id=7.11 box=35
    name_en: "Are you a family-owned special purpose entity?"
    name_zh: "你是否为家族投资控股工具的特殊目的实体？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS/notes indicate family-owned investment structure ELSE No"
    default_value: "No"

  @field field_id=7.12 box=36
    name_en: "Are you an eligible single family office?"
    name_zh: "你是否为合资格单一家族办公室？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF family office structure mentioned ELSE No"
    default_value: "No"

@part part_number=8
  part_name_en: "TRANSACTIONS FOR / WITH NON-RESIDENTS"
  part_name_zh: "与非居民人士的交易"
  field_count: 5

  @field field_id=8.1.1 box=37
    name_en: "Sell goods or provide services in Hong Kong on behalf of a non-resident?"
    name_zh: "是否代非居民人士在香港销售货品或提供服务？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS mentions agency for non-resident ELSE No"
    default_value: "No"

  @field field_id=8.1.2 box=38
    name_en: "Receive income for non-resident person from Hong Kong trade/business?"
    name_zh: "是否代非居民人士收取源自香港的贸易或业务收入？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS mentions agency income for non-resident ELSE No"
    default_value: "No"

  @field field_id=8.1.3 box=39
    name_en: "Make value creation contributions in Hong Kong for non-resident IP?"
    name_zh: "是否在香港为非居民的知识产权作出价值创造贡献？"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: financial_statements
    derivation_rule: "Yes IF FS mentions IP development for non-resident ELSE No"
    default_value: "No"

  @field field_id=8.2 box=40
    name_en: "Hire charges paid/accrued to non-residents for movable property in Hong Kong"
    name_zh: "就香港动产的使用权支付给/应计给非居民人士的租用费"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["hire charges", "rental", "lease"]
    default_value: "0"

  @field field_id=8.3 box=41
    name_en: "Fees paid/accrued to non-residents for professional services in Hong Kong"
    name_zh: "就香港专业服务支付给/应计给非居民人士的费用"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["professional fees", "consultancy fees", "non-resident"]
    default_value: "0"

@part part_number=9
  part_name_en: "DETAILS OF SUPPLEMENTARY FORM(S) UPLOADED"
  part_name_zh: "已上传补充表格详情"
  field_count: 22

  @field field_id=9.1 box=42
    name_en: "Form S1 - Person electing for two-tiered profits tax rates"
    name_zh: "表格S1"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: fixed
    fixed_value: "No"
    reasoning: "Per company rule, supplementary forms are not applicable"
    company_rule: "No"

  @field field_id=9.2 box=43
    name_en: "Form S2 - Transfer pricing and international tax obligations"
    name_zh: "表格S2"
    value_type: boolean
    fill_rule: 'Tick "Yes" or "No"'
    required: true
    source_preference: fixed
    fixed_value: "No"
    reasoning: "Per company rule, supplementary forms are not applicable"
    company_rule: "No"

  @field field_id=9.3 box=44
