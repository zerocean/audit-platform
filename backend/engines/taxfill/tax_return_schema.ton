    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    @taxcomp_mapping
      asset_type: "machinery|plant"
      allowance_type: "annual"
    default_value: "0"

  @field field_id=11.10 box=103
    name_en: "Machinery or Plant - Balancing Allowance"
    name_zh: "机械或工业装置 - 结余免税额"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    @taxcomp_mapping
      asset_type: "machinery|plant"
      allowance_type: "balancing"
    default_value: "0"

  @field field_id=11.11 box=104
    name_en: "Machinery or Plant - Balancing Charge"
    name_zh: "机械或工业装置 - 结余课税"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    @taxcomp_mapping
      asset_type: "machinery|plant"
      allowance_type: "balancing_charge"
    default_value: "0"

@part part_number=12
  part_name_en: "FINANCIAL DATA"
  part_name_zh: "财务数据"
  field_count: 23

  @field field_id=12.1 box=105
    name_en: "Gross income"
    name_zh: "总收入"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: derived
    @decision_tree
      description: "Gross income = Total of all revenue and income items (Revenue + Other revenue + Other income)"
      step: "In the FS Notes, find the note about Revenue. Look for the subtotal or total row that sums ALL revenue and income items listed."
      step: "This row often has label: null or role: subtotal — that's the gross income total. Use its value."
      step: "If no subtotal row found, calculate: Gross income = Revenue + Other revenue/income items from the Income Statement or Revenue Note."
      step: "Fallback: try label matching for 'gross income', 'gross revenue', 'total revenue'."
    default_value: "0"

  @field field_id=12.2 box=106
    name_en: "Turnover"
    name_zh: "营业额"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["turnover", "revenue", "sales"]
    default_value: "0"

  @field field_id=12.3 box=107
    name_en: "Opening inventories"
    name_zh: "期初存货"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["opening inventories", "opening stock"]
    default_value: "0"

  @field field_id=12.5 box=109
    name_en: "Closing inventories"
    name_zh: "期末存货"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["closing inventories", "closing stock"]
    default_value: "0"

  @field field_id=12.4 box=108
    name_en: "Purchases"
    name_zh: "采购"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: derived
    @decision_tree
      description: "Purchases = Closing inventories - Opening inventories + Purchases-related items from Cost of sales"
      step: "In TaxComp Schedule 1, look under Cost of sales. Identify the item(s) that represent raw material / goods purchases — these are typically labeled 'Materials', 'Purchases', 'Cost of goods purchased', 'Raw materials', etc."
      step: "Exclude items that are service/labor costs (e.g. 'Subcontractor fee', 'Labor', 'Processing fee') — those are NOT purchases."
      step: "Use your accounting judgment to distinguish purchases from service costs."
      step: "Purchases = Closing_inventories(12.5) - Opening_inventories(12.3) + Purchases_items_amount"
      step: "Fallback: try FS label 'purchases' or 'cost of purchases'"
      step: "If still not found, 0 + manual_review"
    default_value: "0"

  @field field_id=12.6 box=110
    name_en: "Gross profit"
    name_zh: "毛利"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: derived
    @decision_tree
      description: "Gross profit = Turnover(12.2) - Purchases items from TaxComp Cost of sales"
      step: "In TaxComp Schedule 1, under Cost of sales, find items that are raw material/goods purchases (keywords: 'Materials', 'Purchases', 'goods'). Do NOT include service costs like subcontractor."
      step: "Gross profit = Box_12.2(Turnover) - Sum_of_purchases_items"
      step: "CRITICAL: This formula ALWAYS applies. Even if the FS Income Statement shows a 'Gross profit' line with a different number, IGNORE IT. The FS Gross profit includes subcontractor/service costs which are NOT purchases. The tax return definition is narrower."
    default_value: "0"
    mutually_exclusive_with: [12.7]

  @field field_id=12.7 box=111
    name_en: "Gross loss"
    name_zh: "毛损"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["gross loss"]
    default_value: "0"
    mutually_exclusive_with: [12.6]

  @field field_id=12.8 box=112
    name_en: "Dividend income"
    name_zh: "股息收入"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["dividend income", "dividends received"]
    default_value: "0"

  @field field_id=12.9 box=113
    name_en: "Interest income"
    name_zh: "利息收入"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["interest income", "bank interest", "deposit interest"]
    default_value: "0"

  @field field_id=12.10 box=114
    name_en: "Interest expense"
    name_zh: "利息支出"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["interest expense", "finance costs", "bank interest expense"]
    default_value: "0"

  @field field_id=12.11 box=115
    name_en: "Employee and director remuneration"
    name_zh: "雇员及董事薪酬"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: derived
    @decision_tree
      description: "Employee & director remuneration = Director's remuneration + Salaries/Staff costs from TaxComp Schedule 1"
      step: "In TaxComp Schedule 1, find 'Director's remuneration' (or 'Directors' remuneration') — extract its amount."
      step: "Also search for 'Salaries' — extract its amount if found."
      step: "Total = Director's_remuneration_amount + Salaries_amount (if salaries found, else just Director's remuneration)"
      step: "ONLY include items explicitly labeled 'Director's remuneration' or 'Salaries'. Do NOT include 'Staff welfare', 'medical', 'pension', 'bonus', or other employee benefits — those are NOT remuneration for this box."
      step: "Fallback: use FS keywords 'staff costs', 'employee benefits', 'salaries', 'directors' emoluments'"
      step: "If nothing found, 0 + manual_review"
    default_value: "0"

  @field field_id=12.12 box=116
    name_en: "Share-based payments"
    name_zh: "以股份为基础的付款"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["share-based payments", "equity-settled share-based payments"]
    default_value: "0"

  @field field_id=12.13 box=117
    name_en: "Commission payments"
    name_zh: "佣金支出"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["commission", "brokerage"]
    default_value: "0"

  @field field_id=12.14 box=118
    name_en: "Intellectual property payments"
    name_zh: "知识产权付款"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["royalty", "intellectual property", "licence fees"]
    default_value: "0"

  @field field_id=12.15 box=119
    name_en: "Management and consultancy fee payments"
    name_zh: "管理及顾问费付款"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["management fee", "consultancy fee", "professional fees"]
    default_value: "0"

  @field field_id=12.16 box=120
    name_en: "Contractor and subcontractor charges"
    name_zh: "承办商及分包商费用"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["contractor", "subcontractor", "outsourcing"]
    default_value: "0"

  @field field_id=12.17 box=121
    name_en: "Bad debts"
    name_zh: "坏账"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["bad debts", "impairment loss", "trade receivables impairment"]
    default_value: "0"

  @field field_id=12.18 box=122
    name_en: "Net profit per account"
    name_zh: "账面上净利润"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: derived
    @decision_tree
      description: "Net profit per account = 'Profit for the year' from Tax Computation Schedule 1"
      step: "In TaxComp Schedule 1 (Detailed Income Statement), find the @row with label 'Profit for the year' — this is the net profit per account. Use its value from the HK$ column."
      step: "This is the accounting profit BEFORE tax adjustments shown in the tax computation. Do NOT use the FS Income Statement's 'Profit for the year' (which may be after tax). The tax return wants the Schedule 1 figure."
      step: "If 'Profit for the year' not found in TaxComp, try 'net profit', then FS keywords as fallback."
      step: "If nothing found, 0 + manual_review"
    default_value: "0"
    mutually_exclusive_with: [12.19]

  @field field_id=12.19 box=123
    name_en: "Net loss per account"
    name_zh: "账面上净亏损"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["loss for the year", "net loss"]
    default_value: "0"
    mutually_exclusive_with: [12.18]

  @field field_id=12.20 box=124
    name_en: "Accounts receivable (trade)"
    name_zh: "应收账款（贸易）"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: tax_computation
    source_keywords: ["trade receivables", "accounts receivable", "debtors"]
    default_value: "0"

  @field field_id=12.21 box=125
    name_en: "Accounts payable (trade)"
    name_zh: "应付账款（贸易）"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["trade payables", "accounts payable", "creditors"]
    default_value: "0"

  @field field_id=12.22 box=126
    name_en: "Issued share capital"
    name_zh: "已发行股份股本"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["issued share capital", "share capital"]
    default_value: "0"
    validation_rules: ["must_equal_fs_share_capital"]

  @field field_id=12.23 box=127
    name_en: "Total value of assets"
    name_zh: "资产总值"
    value_type: amount
    fill_rule: 'If NIL, enter "0". Exclude cents.'
    required: true
    source_preference: financial_statements
    source_keywords: ["total assets"]
    default_value: "0"
    validation_rules: ["must_equal_fs_total_assets"]

@part part_number=13
  part_name_en: "DECLARATION"
  part_name_zh: "声明"
  field_count: 2

  @field field_id=13.1 box=128
    name_en: "Declaration by Secretary / Manager / Director / Investment Manager / Liquidator"
    name_zh: "由秘书/经理/董事/投资经理/清盘人作出的声明"
    value_type: text
    fill_rule: "Enter full name, designation and sign"
    required: true
    source_preference: manual
    reasoning: "Must be signed by authorized person - manual entry required"

  @field field_id=13.2 box=129
    name_en: "Declaration by Service Provider (if applicable)"
    name_zh: "由服务提供者作出的声明（如适用）"
    value_type: text
    fill_rule: "Enter full name, designation and sign if Service Provider engaged"
    required: false
    source_preference: manual
    reasoning: "Only applicable if Service Provider is engaged to furnish this return"

@cross_validations
  @validation rule_id=V1
    description: "Part 1.1 must equal Tax Computation Assessable Profit"
    severity: ERROR
    check: "Part_1_1 == taxcomp.assessable_profit"
    failure_action: "validation_status: fail, needs_manual_review: true"

  @validation rule_id=V2
    description: "Part 1.1 and 1.2 mutual exclusion"
    severity: ERROR
    check: "NOT (Part_1_1 > 0 AND Part_1_2 > 0)"
    failure_action: "validation_status: fail"

  @validation rule_id=V3
    description: "Part 12.6 and 12.7 mutual exclusion"
    severity: ERROR
    check: "NOT (Part_12_6 > 0 AND Part_12_7 > 0)"
    failure_action: "validation_status: fail"

  @validation rule_id=V4
    description: "Part 12.18 and 12.19 mutual exclusion"
    severity: ERROR
    check: "NOT (Part_12_18 > 0 AND Part_12_19 > 0)"
    failure_action: "validation_status: fail"

  @validation rule_id=V5
    description: "Part 12.22 must equal FS Issued share capital"
    severity: ERROR
    check: "Part_12_22 == fs.issued_share_capital"
    failure_action: "validation_status: fail"

  @validation rule_id=V6
    description: "Part 12.23 must equal FS Total assets"
    severity: ERROR
    check: "Part_12_23 == fs.total_assets"
    failure_action: "validation_status: fail"

  @validation rule_id=V7
    description: "Part 11 total allowances approximately equal Tax Comp depreciation adjustment"
    severity: WARNING
    check: "ABS(SUM(Part_11_all_allowances) - taxcomp.total_depreciation) < tolerance"
    failure_action: "validation_status: warning"

  @validation rule_id=V8
    description: "All amount fields must have a value (0 if NIL, never null)"
    severity: ERROR
    check: "ALL amount_fields != null AND amount_fields != ''"
    failure_action: "validation_status: fail"

  @validation rule_id=V9
    description: "Part 12.6 Gross profit consistency check (Gross income - Purchases + Opening - Closing ≈ Gross profit/loss)"
    severity: WARNING
    check: "ABS((Part_12_1 OR Part_12_2) - Part_12_4 + Part_12_3 - Part_12_5 - (Part_12_6 OR Part_12_7)) < tolerance"
    failure_action: "validation_status: warning"
    note: "Gross income and Turnover definitions may differ; this is advisory only"