# Audit Platform — 环境变量
# 复制此文件为 .env 并填写实际值

# —— DashScope API (必填) ——
DASHSCOPE_API_KEY=sk-your-key-here

# —— Vision Parser ——
VISION_MODEL=qwen3.6-flash
VISION_BATCH_SIZE=1
VISION_MAX_PARALLEL=10
VISION_TIMEOUT=1800

# —— LLM Audit ——
AUDIT_MODEL=deepseek-v4-flash

# —— admin-dashboard 上报 (可选) ——
ADMIN_API_URL=http://localhost:5003/api/v1
INTERNAL_API_KEY=

# —— 阿里云 OSS ——
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=audit-platform
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# —— 端口 ——
PORT=8765
